{
  "name": "code-golf-minifier",
  "displayName": "Code Golf Minifier",
  "description": "Minify C/C++ code for code golf while preserving behavior.",
  "version": "0.0.2",
  "publisher": "cjdyer",
  "license": "SEE LICENSE IN LICENSE",
  "icon": "img.png",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Formatters",
    "Other"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cjdyer/code-golf-minifier.git"
  },
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codeGolf.minifyCpp",
        "title": "Code Golf: Minify C/C++"
      }
    ],
    "keybindings": [
      {
        "command": "codeGolf.minifyCpp",
        "key": "ctrl+alt+m",
        "mac": "cmd+alt+m",
        "when": "editorTextFocus"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "vscode-test",
    "vscode:prepublish": "npm run compile",
    "package": "vsce package",
    "publish": "vsce publish && ovsx publish"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.7",
    "@types/node": "^25.5.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.7.1",
    "ovsx": "^0.10.9",
    "typescript": "^5.9.3"
  }
}
